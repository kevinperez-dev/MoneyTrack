# Puerto donde se ejecuta el backend
PORT=4000

# Entorno de ejecución: development o production
NODE_ENV=development

# Cadena de conexión PostgreSQL de ejemplo
DATABASE_URL=postgresql://usuario:password@host:5432/base_de_datos

# Clave secreta de ejemplo para JWT
JWT_SECRET=cambia_esta_clave_por_una_muy_segura

# URL permitida del frontend
FRONTEND_URL=http://localhost:5173